rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (default-deny catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Hardened global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-+:]+$');
    }

    // Rules for User documents and subcollections
    match /users/{userId} {
      allow read, write: if isOwner(userId) && isValidId(userId);

      match /dailyStates/{date} {
        allow read, write: if isOwner(userId) && isValidId(userId) && isValidId(date);
      }

      match /visionBoard/{itemId} {
        allow read, write: if isOwner(userId) && isValidId(userId) && isValidId(itemId);
      }

      match /steps/{logId} {
        allow read, write: if isOwner(userId) && isValidId(userId) && isValidId(logId);
      }

      match /tasks/{taskId} {
        allow read, write: if isOwner(userId) && isValidId(userId) && isValidId(taskId);
      }

      match /ideas/{ideaId} {
        allow read, write: if isOwner(userId) && isValidId(userId) && isValidId(ideaId);
      }
    }
  }
}
